<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
{% for page_entry in site.data.pages %}
{% assign translations = page_entry[1] %}
{% for lang_entry in translations %}
  <url>
    <loc>{{ lang_entry[1] | absolute_url }}</loc>
{% if translations.size > 1 %}
{% for alt in translations %}
    <xhtml:link rel="alternate" hreflang="{{ alt[0] }}" href="{{ alt[1] | absolute_url }}" />
{% endfor %}
{% endif %}
  </url>
{% endfor %}
{% endfor %}
</urlset>
